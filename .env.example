# ──────────────────────────────────────────────
# Nutribot Backend — Environment Variables
# Copiar como .env y rellenar los valores reales
# ──────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://nutribot:nutribot@localhost:5432/nutribot

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=nutribot

# Workers
INBOX_POLL_INTERVAL_SECONDS=1.0
OUTBOX_POLL_INTERVAL_SECONDS=1.0
EXTRACTION_POLL_INTERVAL_SECONDS=5.0
SWEEPER_INTERVAL_SECONDS=60.0
ZOMBIE_TIMEOUT_MINUTES=10
MAX_RETRY_COUNT=3

# App
LOG_LEVEL=INFO
DEBUG=false

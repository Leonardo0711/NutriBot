# ──────────────────────────────────────────────
# Nutribot Backend — Environment Variables
# Copiar como .env y rellenar los valores reales
# ──────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://nutribot:nutribot@localhost:5432/nutribot

# Redis (dedicated instance for queues, locks, cache)
REDIS_URL=redis://nutribot-redis:6379/0

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=nutribot

# Workers
INBOX_POLL_INTERVAL_SECONDS=1.0
OUTBOX_POLL_INTERVAL_SECONDS=1.0
SWEEPER_INTERVAL_SECONDS=60.0
ZOMBIE_TIMEOUT_MINUTES=10
MAX_RETRY_COUNT=3
PROCESSING_LOCK_TTL_SECONDS=60

# App
LOG_LEVEL=INFO
DEBUG=false

# Modo de operación:
#   monolith = API + workers en un solo proceso (default)
#   api      = Solo API, workers corren con run_worker.py
NUTRIBOT_MODE=monolith

# Legacy Rate Limiting (compatibilidad)
RATE_LIMIT_MAX_MESSAGES=10
RATE_LIMIT_WINDOW_SECONDS=60

# Webhook Security
WEBHOOK_SECRET=change-me
WEBHOOK_ALLOWED_EVENTS=messages.upsert
WEBHOOK_RATE_LIMIT_MAX_IP=1000
WEBHOOK_RATE_LIMIT_MAX_PHONE=60
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_DEDUP_TTL_SECONDS=300
